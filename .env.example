# Copy to .env.local for local dev. Production values go in Railway → Variables.

# ─── Required ───────────────────────────────────────────────────────

# Postgres connection. Railway provides this automatically as a reference
# variable when you add a Postgres service to the project. For local dev:
#   postgresql://treecommerce:treecommerce_dev@localhost:5433/treecommerce_cockpit
DATABASE_URL=

# Zabbix JSON-RPC endpoint + read-only token. Production uses the same
# token as dev for now (TBD: rotate when SP IT confirms).
ZABBIX_URL=https://monitoring.strongpoint.com/api_jsonrpc.php
ZABBIX_TOKEN=

# ─── Optional ───────────────────────────────────────────────────────

# 12eat sales API environment — "prod" or "test". Currently unused by
# Retellect dashboard; kept for forward-compat with TC pilots.
TWELVEEAT_ENV=prod

# Override the version stamp shown in /api/version + footer + About panel.
# Useful in CI when git history isn't available (shallow clones, Docker).
# AKPILOT_VERSION_OVERRIDE=
# AKPILOT_COMMIT_OVERRIDE=
# AKPILOT_COMMIT_FULL_OVERRIDE=
# AKPILOT_BRANCH_OVERRIDE=
